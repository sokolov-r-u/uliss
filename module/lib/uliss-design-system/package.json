{
  "name": "@uliss/design-system",
  "version": "0.0.1",
  "type": "module",
  "description": "Uliss design system — CSS tokens, fonts and React components shared by the auth server (Thymeleaf) and the web SPA (React).",
  "exports": {
    ".": "./src/react/index.ts",
    "./styles.css": "./src/styles.css",
    "./tokens/*": "./src/tokens/*",
    "./assets/*": "./src/assets/*"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "postcss \"src/**/*.css\" --base src --dir dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "typescript": "^5.7.3",
    "@types/react": "^19.0.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
